#include <stdio.h>
#include <stdlib.h>

void sort(int arr[], int n)
{
    for(int i=0;i<n;i++)
        for(int j=i+1;j<n;j++)
            if(arr[i]>arr[j])
            {
                int temp=arr[i];
                arr[i]=arr[j];
                arr[j]=temp;
            }
}

int main()
{
    int arr[10], n=10;

    printf("Enter 10 numbers:\n");
    for(int i=0;i<n;i++)
        scanf("%d",&arr[i]);

    sort(arr,n);

    printf("Sorted data:\n");
    for(int i=0;i<n;i++)
        printf("%d ",arr[i]);

    return 0;
}
